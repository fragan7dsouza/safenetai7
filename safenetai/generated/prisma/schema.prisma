// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ScanType {
  link
  email
  document
  domain
}

enum ScanStatus {
  safe
  suspicious
  dangerous
}

enum ReportType {
  link
  email
  document
  other
}

enum ReportStatus {
  pending
  approved
  rejected
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  scans        Scan[]
  reports      Report[]
  uploads      FileUpload[]
}

model Scan {
  id          String     @id @default(cuid())
  type        ScanType
  status      ScanStatus
  inputText   String?
  inputUrl    String?
  inputDomain String?
  confidence  Float?
  riskScore   Int?
  explanation String?
  keywords    Json?
  rawResponse Json
  createdAt   DateTime   @default(now())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model Report {
  id                   String       @id @default(cuid())
  title                String
  type                 ReportType
  description          String
  url                  String?
  email                String?
  reporterInfo         String?
  status               ReportStatus @default(pending)
  moderationVerdict    String?
  moderationReason     String?
  moderationConfidence Float?
  moderationRaw        Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  approvedAt           DateTime?
  userId               String?
  user                 User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  uploads              FileUpload[]

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model FileUpload {
  id         String   @id @default(cuid())
  fileName   String
  mimeType   String
  sizeBytes  Int
  base64Data String
  createdAt  DateTime @default(now())
  reportId   String?
  report     Report?  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([reportId])
  @@index([userId, createdAt])
}
